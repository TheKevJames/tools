{
    "extends": [
        "github>thekevjames/tools:personal",
        "github>thekevjames/tools//renovate/version-as-app.json5",
    ],
    "packageRules": [
        {
            "matchManagers": ["dockerfile"],
            "matchDepNames": [
                "library/caddy",
            ],
            "matchUpdateTypes": ["minor"],
            "automerge": true,
        },
        {
            "matchFileNames": [
                "docker-atc1441-exporter/Dockerfile",
            ],
            "matchDepNames": [
                "python",
                "python/cpython",
            ],
            "allowedVersions": "3.9",
        },
        {
            "matchFileNames": [
                ".circleci/config.yml",
                ".pre-commit-config.yaml",
            ],
            "matchDepNames": [
                "python",
                "python/cpython",
            ],
            "allowedVersions": "3.11",
        },
    ],
}
